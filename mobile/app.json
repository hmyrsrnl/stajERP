{
  "expo": {
    "name": "mobile",
    "slug": "mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/indir.jpeg",
    "scheme": "mobile",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,

    "splash": {
      "image": "./assets/images/indir.jpeg",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },

    "android": {
      "backgroundColor": "#ffffff"
    },

    "web": {
      "output": "single"
    },

    "plugins": [
      "expo-asset",
      "expo-font",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#ffffff",
          "image": "./assets/images/indir.jpeg",
          "resizeMode": "contain",
          "imageWidth": 1100
        }
      ]
    ]
  }
}